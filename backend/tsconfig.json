{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
"moduleResolution": "Bundler",
    "allowImportingTsExtensions": false,
    

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "skipLibCheck": true,

    "types": ["node"],
    "lib": ["ES2022"],

    "sourceMap": true,
    "resolveJsonModule": true
  },

  "include": ["src"],
  "exclude": ["node_modules"]
}
